# PostgreSQL connection string used by Drizzle (required at runtime and for migrations)
# Example: postgres://user:password@host:5432/database
DATABASE_URL="postgres://postgres:postgres@localhost:5432/iranazad"

# Secret used for HMAC hashing of identity and anti-fraud signals (required)
# Must be long, random, and managed as a secret in production
PETITION_HMAC_SECRET="[HMAC_SECRET]"

# Optional runtime metadata
NODE_ENV="development"
PORT="3000"

# Public GitHub repository URL used in footer link (client-side)
VITE_GITHUB_REPO_URL="https://github.com/SireJeff/iranazad"
